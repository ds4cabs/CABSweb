# =============================================================================
# CABSweb environment configuration
# Copy to `.env.local` and fill in. Every integration is optional in dev — the
# app falls back to seeded mock data when a key is absent (see src/lib/env.ts).
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CABSweb

# --- Supabase (backend + Postgres + storage) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authentication (choose ONE provider; Clerk is the default) --------------
# AUTH_PROVIDER=clerk | auth0
AUTH_PROVIDER=clerk
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Auth0 (if AUTH_PROVIDER=auth0)
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# --- OpenAI (search, recommendations, generation, assistant) -----------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Vector database (semantic search over CABS knowledge) -------------------
# VECTOR_PROVIDER=pgvector | pinecone | qdrant
VECTOR_PROVIDER=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=cabs-knowledge

# --- HubSpot (CRM + member engagement) ---------------------------------------
HUBSPOT_ACCESS_TOKEN=

# --- Stripe (membership + payments) ------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Events (Zoom + Eventbrite) ----------------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
EVENTBRITE_API_TOKEN=
