# =============================================================================
# CABSweb environment configuration
# Copy to `.env.local` and fill in. Every integration is optional in dev — the
# app falls back to seeded mock data when a key is absent (see src/lib/env.ts).
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CABSweb

# --- Supabase (backend + Postgres + storage) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authentication (Auth.js / NextAuth v5 — Google sign-in) -----------------
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Google OAuth client (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- OpenAI (search, recommendations, generation, assistant) -----------------
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Vector database (semantic search over CABS knowledge) -------------------
# VECTOR_PROVIDER=pgvector | pinecone | qdrant
VECTOR_PROVIDER=pgvector
PINECONE_API_KEY=
PINECONE_INDEX=cabs-knowledge

# --- HubSpot (CRM + member engagement) ---------------------------------------
HUBSPOT_ACCESS_TOKEN=

# --- Stripe (membership + payments) ------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Events (Zoom + Eventbrite) ----------------------------------------------
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
EVENTBRITE_API_TOKEN=
